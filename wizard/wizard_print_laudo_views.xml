<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Formulário do Wizard -->
    <record id="view_wizard_print_laudo_form" model="ir.ui.view">
        <field name="name">wizard.print.laudo.form</field>
        <field name="model">wizard.print.laudo</field>
        <field name="arch" type="xml">
            <form string="Selecionar Materiais para o Laudo">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="ciclo_id" readonly="1"/>
                        </h1>
                        <h3 class="text-muted">
                            Laudo de Liberação de Produtos
                        </h3>
                    </div>
                    
                    <group>
                        <field name="material_count" readonly="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Materiais Disponíveis" name="materials">
                            <div class="alert alert-info" role="alert" style="margin-bottom: 10px;">
                                <strong>Instruções:</strong> 
                                Marque os materiais que deseja incluir no laudo de liberação clicando nas checkboxes. 
                                Somente os materiais marcados aparecerão no documento final.
                            </div>
                            
                            <field name="material_line_ids" nolabel="1">
                                <tree decoration-success="True">
                                    <field name="material_descricao"/>
                                    <field name="fabricante_nome"/>
                                    <field name="lote"/>
                                    <field name="quantidade"/>
                                    <field name="unidade"/>
                                    <field name="validade"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Assinatura" name="signature">
                            <div class="alert alert-info" role="alert" style="margin-bottom: 10px;">
                                <strong>Assinatura no laudo:</strong>
                                Se o ciclo já foi <strong>assinado eletronicamente</strong> no formulário do ciclo (botão Assinar ciclo),
                                o PDF do laudo usa <strong>os mesmos dados</strong> do relatório &quot;Impressão de ciclos&quot; (imagem, conselho, CPF, data).
                                Caso contrário, use abaixo: assinatura automática da empresa, envio de PNG ou quadro de desenho.
                            </div>
                            <group>
                                <field name="signature_type" widget="radio"/>
                                <field name="signature_image" widget="image" options="{'size': [200, 80]}"
                                       attrs="{'invisible': [('signature_type', '=', 'auto')], 'required': [('signature_type', 'in', ['upload', 'draw'])]}"/>
                                <field name="signer_name" placeholder="Nome do responsável"/>
                                <field name="signer_title" placeholder="Ex.: Garantia de qualidade"/>
                                <field name="signature_date"/>
                            </group>
                            <div class="mt-3" attrs="{'invisible': [('signature_type', '!=', 'draw')]}">
                                <a href="/laudo/assinatura/quadro" target="_blank" class="btn btn-link">
                                    <i class="fa fa-pencil"/> Abrir quadro para assinar digitalmente
                                </a>
                                <p class="text-muted small">
                                    Desenhe a assinatura no quadro, baixe o PNG e use &quot;Enviar imagem&quot; acima, ou envie a imagem aqui após desenhar.
                                </p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                
                <footer>
                    <button name="action_print_laudo" 
                            string="Gerar Laudo" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-print"
                            attrs="{'invisible': [('material_count', '=', 0)]}"/>
                    <button string="Cancelar" 
                            class="btn-secondary" 
                            special="cancel"/>
                    
                    <div class="text-muted" style="display: inline-block; margin-left: 20px;"
                         attrs="{'invisible': [('material_count', '>', 0)]}">
                        <i class="fa fa-exclamation-triangle"/> 
                        Selecione pelo menos um material para gerar o laudo
                    </div>
                </footer>
            </form>
        </field>
    </record>

    <!-- Ação para abrir o Wizard (usada internamente) -->
    <record id="action_wizard_print_laudo" model="ir.actions.act_window">
        <field name="name">Gerar Laudo de Liberação</field>
        <field name="res_model">wizard.print.laudo</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

